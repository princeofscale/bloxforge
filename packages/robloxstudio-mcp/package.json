{
  "name": "@princeofscale/bloxforge",
  "version": "3.0.0-rc.1",
  "description": "Open-source AI agent toolkit for building, inspecting, testing, and automating Roblox games in Studio.",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "bloxforge": "dist/index.js"
  },
  "files": [
    "dist/**/*",
    "studio-plugin/**/*",
    "assets/**/*"
  ],
  "scripts": {
    "build": "tsup",
    "prepack": "node ../../scripts/prepack.mjs",
    "postpack": "node ../../scripts/postpack.mjs"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "roblox",
    "roblox-studio",
    "model-context-protocol",
    "claude-code",
    "codex",
    "cursor",
    "gemini",
    "ai-agent",
    "ai-coding",
    "luau",
    "roblox-plugin",
    "game-development",
    "automation",
    "open-source",
    "developer-tools"
  ],
  "author": {
    "name": "princeofscale",
    "url": "https://github.com/princeofscale"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/princeofscale/bloxforge.git"
  },
  "homepage": "https://github.com/princeofscale/bloxforge#readme",
  "bugs": {
    "url": "https://github.com/princeofscale/bloxforge/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "cors": "^2.8.5",
    "express": "^4.22.2",
    "node-fetch": "^3.3.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@princeofscale/bloxforge-core": "*"
  }
}
